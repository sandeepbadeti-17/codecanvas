generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())      // unique identity of the user
  name      String?                              
  email     String   @unique                     // main identity key
  image     String?                              

  accounts  Account[]                            // all login methods attached to this user

  createdAt DateTime @default(now())            
  updatedAt DateTime @updatedAt                 
}

model Account {
  id                String  @id @default(cuid())
  userId            String                           // FK to User
  provider          String                           // google | github | credentials
  providerAccountId String                           // unique id from provider (email for credentials)
  
  // ONLY for credentials login
  passwordHash      String?                         

  access_token      String?                          // OAuth tokens
  refresh_token     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])           // prevent duplicate accounts
}